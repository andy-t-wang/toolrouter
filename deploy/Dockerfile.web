FROM node:22-slim

WORKDIR /app

COPY package.json package-lock.json tsconfig.json ./
COPY apps/api/package.json ./apps/api/package.json
COPY apps/mcp/package.json ./apps/mcp/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY apps/worker/package.json ./apps/worker/package.json
COPY packages/auth/package.json ./packages/auth/package.json
COPY packages/cache/package.json ./packages/cache/package.json
COPY packages/db/package.json ./packages/db/package.json
COPY packages/router-core/package.json ./packages/router-core/package.json

RUN npm ci --workspace @toolrouter/web --include-workspace-root --no-audit --fund=false --prefer-offline

COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts

ARG NEXT_PUBLIC_TOOLROUTER_API_URL=""
ARG NEXT_PUBLIC_TOOLROUTER_APP_URL=""
ARG NEXT_PUBLIC_SUPABASE_URL=""
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=""

ENV NEXT_PUBLIC_TOOLROUTER_API_URL=$NEXT_PUBLIC_TOOLROUTER_API_URL
ENV NEXT_PUBLIC_TOOLROUTER_APP_URL=$NEXT_PUBLIC_TOOLROUTER_APP_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm --workspace @toolrouter/web run build

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["npm", "run", "start:web"]
