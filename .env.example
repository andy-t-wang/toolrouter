# Copy to .env for local development or configure in the deployment secret store.

# API service
TOOLROUTER_API_HOST=127.0.0.1
TOOLROUTER_API_PORT=9402
TOOLROUTER_CORS_ORIGIN=http://127.0.0.1:3000

# Local deterministic mode. Does not spend money.
ROUTER_DEV_MODE=true
AGENTKIT_ROUTER_DEV_API_KEY=dev_agentkit_router_key

# Web dashboard
NEXT_PUBLIC_TOOLROUTER_API_URL=http://127.0.0.1:9402
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase. Required for hosted/prod persistence and dashboard login.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Redis-compatible managed cache. Use DigitalOcean Managed Valkey for production.
VALKEY_URL=
REDIS_URL=
TOOLROUTER_RATE_LIMIT_PER_MINUTE=60
TOOLROUTER_IP_RATE_LIMIT_PER_MINUTE=120
TOOLROUTER_DEV_CREDIT_BALANCE_USD=100
TOOLROUTER_MAX_TOP_UP_USD=500

# Crossmint credits and hosted wallets. Required for production credit top-ups and signing.
CROSSMINT_ENV=staging
CROSSMINT_SERVER_SIDE_API_KEY=
CROSSMINT_CLIENT_SIDE_API_KEY=
CROSSMINT_WEBHOOK_SECRET=
CROSSMINT_USDC_TOKEN_LOCATOR=base:usdc
CROSSMINT_CHAIN=base
CROSSMINT_SERVER_SIGNER_ADDRESS=
CROSSMINT_SIGNER_SECRET=
CROSSMINT_LIVE_WALLET_LOCATOR=
CROSSMINT_LIVE_WALLET_ADDRESS=

# Local wallet and x402 policy. AGENT_WALLET_PRIVATE_KEY is for local/dev smoke tests only.
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=
X402_DEFAULT_CHAIN_ID=eip155:8453
X402_ALLOWED_CHAINS=eip155:8453,eip155:480
X402_ALLOWED_HOSTS=api.exa.ai,x402.browserbase.com
# Emergency wallet protection. Product-level spend controls will be added later.
X402_MAX_USD_PER_REQUEST=0.05

# Worker
TOOLROUTER_HEALTH_INTERVAL_MS=43200000
