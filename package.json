{
  "name": "toolrouter",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "AgentKit-first x402 tool router for agent endpoints.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @toolrouter/api run dev",
    "dev:mcp": "npm --workspace @worldcoin/toolrouter run dev",
    "dev:web": "npm --workspace @toolrouter/web run dev",
    "dev:worker": "npm --workspace @toolrouter/worker run dev",
    "start:api": "npm --workspace @toolrouter/api run start",
    "start:mcp": "npm --workspace @worldcoin/toolrouter run start",
    "start:web": "npm --workspace @toolrouter/web run start",
    "start:worker": "npm --workspace @toolrouter/worker run start",
    "api:check": "npm --workspace @toolrouter/api run check",
    "mcp:check": "npm --workspace @worldcoin/toolrouter run check",
    "mcp:pack-check": "npm --workspace @worldcoin/toolrouter run build && npm --workspace @worldcoin/toolrouter pack --dry-run",
    "web:check": "npm --workspace @toolrouter/web run check",
    "worker:check": "npm --workspace @toolrouter/worker run check",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"tests/unit/**/*.test.mjs\" \"tests/integration/**/*.test.mjs\" \"tests/e2e/**/*.test.mjs\"",
    "crossmint:signer": "node scripts/crossmint-signer-env.mjs",
    "crossmint:check": "node --env-file-if-exists=.env --import tsx scripts/crossmint-production-check.mjs",
    "billing:retry-funding": "node --env-file-if-exists=.env --import tsx scripts/retry-failed-funding.mjs",
    "datadog:dashboard": "node --env-file-if-exists=.env scripts/datadog-dashboard.mjs",
    "supabase:auth-config": "node scripts/apply-supabase-auth-config.mjs",
    "supabase:auth-email": "node scripts/apply-supabase-auth-email-template.mjs",
    "stripe:local-e2e": "node --env-file-if-exists=.env --import tsx scripts/stripe-local-e2e.mjs",
    "test:supabase:e2e": "node --env-file-if-exists=.env --import tsx scripts/verify-supabase-e2e.mjs",
    "test:live:endpoints": "node --env-file-if-exists=.env --import tsx --test \"tests/live/**/*.live.test.mjs\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {}
}
