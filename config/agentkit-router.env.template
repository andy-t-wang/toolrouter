# ToolRouter environment reference.
# Keep real values out of committed config and generated files.

# Agent/MCP client values. These are safe to pass to personal agent clients.
TOOLROUTER_API_URL=http://127.0.0.1:9402
TOOLROUTER_API_KEY=

# API service runtime.
TOOLROUTER_API_HOST=127.0.0.1
TOOLROUTER_API_PORT=9402
TOOLROUTER_CORS_ORIGIN=http://127.0.0.1:3000

# Dashboard public build-time values.
NEXT_PUBLIC_TOOLROUTER_API_URL=http://127.0.0.1:9402
NEXT_PUBLIC_TOOLROUTER_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Local dashboard only. Never enable this in production.
NEXT_PUBLIC_TOOLROUTER_DEV_AUTH=true

# Server-only Supabase project values used by API, worker, and dashboard.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_PROJECT_REF=
# Local-only management token for applying Supabase hosted Auth settings and email templates.
SUPABASE_ACCESS_TOKEN=

# Supabase Auth production URL and SMTP settings. For Resend SMTP, use an API key as the password.
SUPABASE_AUTH_SITE_URL=https://toolrouter.world
SUPABASE_AUTH_REDIRECT_URLS=https://toolrouter.world/dashboard,https://toolrouter.world/**,http://localhost:3000/**,http://127.0.0.1:3000/**
SUPABASE_SMTP_ADMIN_EMAIL=auth@toolrouter.world
SUPABASE_SMTP_SENDER_NAME=ToolRouter
SUPABASE_SMTP_HOST=smtp.resend.com
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=resend
SUPABASE_SMTP_PASS=

# DigitalOcean Managed Valkey or another Redis-compatible cache.
VALKEY_URL=
REDIS_URL=
TOOLROUTER_RATE_LIMIT_PER_MINUTE=60
TOOLROUTER_IP_RATE_LIMIT_PER_MINUTE=120
TOOLROUTER_AGENTKIT_PREFLIGHT_TIMEOUT_MS=10000
TOOLROUTER_DEV_CREDIT_BALANCE_USD=100
TOOLROUTER_MAX_TOP_UP_USD=5

# Stripe checkout values belong on the API only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ALLOW_LIVE_CHECKOUT=false
TOOLROUTER_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3000/dashboard#billing
TOOLROUTER_CHECKOUT_CANCEL_URL=http://127.0.0.1:3000/dashboard#billing

# Operational alerts for failed settlement.
RESEND_API_KEY=
TOOLROUTER_ALERT_EMAIL=ops@toolrouter.world
TOOLROUTER_ALERT_FROM=ToolRouter <alerts@toolrouter.world>

# Datadog product operations metrics. DD_API_KEY is required on the API service
# for request/AgentKit/Stripe metrics to be emitted.
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_ENV=production
DD_SERVICE=toolrouter-api
DD_SOURCE=toolrouter

# Crossmint hosted wallet values belong on the API only.
CROSSMINT_ENV=staging
CROSSMINT_SERVER_SIDE_API_KEY=
CROSSMINT_CHAIN=base
CROSSMINT_SIGNER_SECRET=
CROSSMINT_TREASURY_WALLET_LOCATOR=evm:alias:toolrouter-treasury-base
CROSSMINT_HEALTH_WALLET_LOCATOR=
CROSSMINT_HEALTH_WALLET_ADDRESS=
CROSSMINT_LIVE_WALLET_LOCATOR=
CROSSMINT_LIVE_WALLET_ADDRESS=

# Local dev wallet and paid fallback values belong on the API and worker only.
# AGENT_WALLET_PRIVATE_KEY is for local/dev smoke testing, not production request execution.
AGENT_WALLET_PRIVATE_KEY=
X402_DEFAULT_CHAIN_ID=eip155:8453
X402_ALLOWED_CHAINS=eip155:8453,eip155:480
X402_ALLOWED_HOSTS=api.exa.ai,x402.browserbase.com,toolrouter.world
X402_MANUS_PAY_TO_ADDRESS=
X402_MAX_USD_PER_REQUEST=0.05
TOOLROUTER_X402_PROVIDER_URL=https://toolrouter.world
TOOLROUTER_MANUS_RESEARCH_PRICE_USD=0.05
TOOLROUTER_MANUS_RESEARCH_PRICE_QUICK_USD=0.03
TOOLROUTER_MANUS_RESEARCH_PRICE_STANDARD_USD=0.05
TOOLROUTER_MANUS_RESEARCH_PRICE_DEEP_USD=0.10
MANUS_API_KEY=

# Worker.
TOOLROUTER_PAID_HEALTH_INTERVAL_MS=3600000
TOOLROUTER_AGENTKIT_HEALTH_INTERVAL_MS=43200000
TOOLROUTER_FUNDING_RETRY_LIMIT=50
