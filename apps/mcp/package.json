{
  "name": "@worldcoin/toolrouter",
  "version": "0.1.1",
  "private": false,
  "license": "Apache-2.0",
  "description": "ToolRouter MCP adapter for AgentKit-first x402 tools.",
  "keywords": [
    "mcp",
    "agentkit",
    "x402",
    "toolrouter",
    "worldcoin"
  ],
  "homepage": "https://toolrouter.world/setup",
  "bugs": {
    "url": "https://github.com/worldcoin/toolrouter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/worldcoin/toolrouter.git",
    "directory": "apps/mcp"
  },
  "type": "module",
  "bin": {
    "toolrouter": "dist/server.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file-if-exists=../../.env --import tsx src/server.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx src/server.ts",
    "check": "tsc -p ../../tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@worldcoin/idkit-core": "^2.1.0"
  }
}
